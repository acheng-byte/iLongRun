#!/usr/bin/env bash
set -euo pipefail

PLUGIN_NAME="ilongrun"
PLUGIN_REPO_SLUG="izscc/iLongRun"
DEFAULT_COPILOT_BIN="copilot"
DEFAULT_SCREEN_BIN="screen"
DEFAULT_MAX_CONTINUES="${COPILOT_ILONGRUN_MAX_CONTINUES:-120}"
ILONGRUN_HOME="${ILONGRUN_HOME:-$HOME/.copilot-ilongrun}"
HELPER_BIN_DIR="$ILONGRUN_HOME/bin"
HELPER_CONFIG_DIR="$ILONGRUN_HOME/config"
MODEL_CONFIG_PATH_DEFAULT="$HELPER_CONFIG_DIR/model-policy.jsonc"
MODEL_AVAILABILITY_PATH_DEFAULT="$HELPER_CONFIG_DIR/model-availability.json"
CODING_PROTOCOL_PATH_DEFAULT="$HELPER_CONFIG_DIR/coding-protocol.jsonc"
LAUNCHER_DIR_NAME=".copilot-ilongrun/launcher"
COPILOT_CONFIG_DIR="${COPILOT_CONFIG_DIR:-$HOME/.copilot}"
COPILOT_BIN="${COPILOT_BIN:-$DEFAULT_COPILOT_BIN}"
SCREEN_BIN="${SCREEN_BIN:-$DEFAULT_SCREEN_BIN}"
LEGACY_PLUGIN_NAME="copilot-mission-control"

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MODEL_CONFIG_PATH="$MODEL_CONFIG_PATH_DEFAULT"
MODEL_AVAILABILITY_PATH="$MODEL_AVAILABILITY_PATH_DEFAULT"
CODING_PROTOCOL_PATH="$CODING_PROTOCOL_PATH_DEFAULT"
SKILL_MODE=""
PLUGIN_ARGS=()
RESOLVED_SKILL_REF=""
RESOLVED_RESUME_SKILL_REF=""

usage() {
  cat <<'EOF'
Usage:
  ilongrun "<task>"
  ilongrun-coding "<coding-task>"
  ilongrun-model [show|<model>|reset] [--refresh]
  ilongrun-prompt "<task>"
  ilongrun-resume [run-id|latest]
  ilongrun-status [run-id|latest]
  ilongrun-doctor [--refresh-model-cache] [--notify-test]

Advanced:
  copilot-ilongrun run [--detach] [--max-continues N] [--model MODEL] [--dry-run] <task>
  copilot-ilongrun coding [--detach] [--max-continues N] [--model MODEL] [--dry-run] <task>
  copilot-ilongrun model [show|<model>|reset] [--refresh]
  copilot-ilongrun prompt [--model MODEL] [--dry-run] <task>
  copilot-ilongrun resume [--detach] [--max-continues N] [--model MODEL] [run-id|latest]
  copilot-ilongrun status [run-id|latest]
  copilot-ilongrun doctor [--refresh-model-cache] [--notify-test]
  copilot-ilongrun selftest

Notes:
  ilongrun-model 在 TTY 终端里支持 Tab 页签：
    全局默认 / run模型 / coding模型
  只有交互式 TUI 才区分这些作用域；
  直接运行 ilongrun-model <model> 仍然是全局模式。
EOF
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

find_bin_from_common_locations() {
  local name="$1"
  local path
  for path in \
    "$HOME/.local/bin/$name" \
    "/opt/homebrew/bin/$name" \
    "/usr/local/bin/$name" \
    "$HOME/bin/$name"
  do
    [ -x "$path" ] && { printf '%s\n' "$path"; return 0; }
  done
  command -v "$name" 2>/dev/null || true
}

helper_path() {
  local name="$1"
  if [ -x "$SCRIPT_DIR/$name" ]; then
    printf '%s\n' "$SCRIPT_DIR/$name"
    return 0
  fi
  if [ -x "$REPO_ROOT/scripts/$name" ]; then
    printf '%s\n' "$REPO_ROOT/scripts/$name"
    return 0
  fi
  if [ -x "$HELPER_BIN_DIR/$name" ]; then
    printf '%s\n' "$HELPER_BIN_DIR/$name"
    return 0
  fi
  return 1
}

copilot_path() { find_bin_from_common_locations "$COPILOT_BIN"; }
screen_path() { find_bin_from_common_locations "$SCREEN_BIN"; }
terminal_notifier_path() { find_bin_from_common_locations terminal-notifier; }

plugin_name_matches() {
  local json_file="$1"
  [ -f "$json_file" ] || return 1
  python3 - "$json_file" "$PLUGIN_NAME" <<'PY' >/dev/null 2>&1
import json, sys
from pathlib import Path
obj = json.loads(Path(sys.argv[1]).read_text(encoding='utf-8'))
raise SystemExit(0 if obj.get('name') == sys.argv[2] else 1)
PY
}

installed_plugin_root() {
  local plugin_dir="$COPILOT_CONFIG_DIR/installed-plugins"
  [ -d "$plugin_dir" ] || return 1
  while read -r f; do
    if plugin_name_matches "$f"; then
      dirname "$f"
      return 0
    fi
  done < <(find "$plugin_dir" -maxdepth 4 -type f -name plugin.json 2>/dev/null)
  return 1
}

has_personal_skill() {
  local name="$1"
  [ -d "$HOME/.copilot/skills/$name" ] || [ -L "$HOME/.copilot/skills/$name" ]
}

resolve_skill_ref() {
  local name="$1"
  if has_personal_skill "$name"; then
    SKILL_MODE="bare"
    PLUGIN_ARGS=()
    RESOLVED_SKILL_REF="/$name"
    return 0
  fi
  if plugin_name_matches "$REPO_ROOT/plugin.json"; then
    SKILL_MODE="local-plugin-dir"
    PLUGIN_ARGS=("$REPO_ROOT")
    RESOLVED_SKILL_REF="/$PLUGIN_NAME:$name"
    return 0
  fi
  local installed_root
  installed_root="$(installed_plugin_root || true)"
  if [ -n "$installed_root" ]; then
    SKILL_MODE="installed-plugin"
    PLUGIN_ARGS=()
    RESOLVED_SKILL_REF="/$PLUGIN_NAME:$name"
    return 0
  fi
  return 1
}

detect_copilot_login() {
  if [ -n "${COPILOT_GITHUB_TOKEN:-}" ]; then printf 'env:COPILOT_GITHUB_TOKEN\n'; return 0; fi
  if [ -n "${GH_TOKEN:-}" ]; then printf 'env:GH_TOKEN\n'; return 0; fi
  if [ -n "${GITHUB_TOKEN:-}" ]; then printf 'env:GITHUB_TOKEN\n'; return 0; fi
  local config_json="$COPILOT_CONFIG_DIR/config.json"
  [ -f "$config_json" ] || return 1
  python3 - "$config_json" <<'PY'
import json, sys
from pathlib import Path
obj = json.loads(Path(sys.argv[1]).read_text(encoding='utf-8'))
last = obj.get('last_logged_in_user') or {}
login = last.get('login')
host = last.get('host') or 'https://github.com'
if login:
    print(f"{login}@{host}")
    raise SystemExit(0)
raise SystemExit(1)
PY
}

legacy_plugin_enabled() {
  python3 - "$COPILOT_CONFIG_DIR/config.json" "$LEGACY_PLUGIN_NAME" <<'PY'
import json, sys
from pathlib import Path
cfg = Path(sys.argv[1])
name = sys.argv[2]
if cfg.exists():
    try:
        obj = json.loads(cfg.read_text(encoding='utf-8'))
    except Exception:
        obj = {}
    for item in obj.get('installed_plugins') or []:
        if item.get('name') == name and item.get('enabled', False):
            raise SystemExit(0)
raise SystemExit(1)
PY
}

auto_uninstall_legacy_plugin() {
  local copilot_cmd="${COPILOT_REAL_BIN:-$(copilot_path || true)}"
  [ -n "$copilot_cmd" ] || return 1
  legacy_plugin_enabled || return 0
  printf '[WARN] 检测到旧插件 %s，正在自动卸载...\n' "$LEGACY_PLUGIN_NAME" >&2
  "$copilot_cmd" plugin uninstall "$LEGACY_PLUGIN_NAME" >/dev/null 2>&1 || true
  sleep 1
  legacy_plugin_enabled && return 1 || return 0
}

cleanup_legacy_workspace_state() {
  local helper
  helper="$(helper_path cleanup_legacy_workspace.py || true)"
  [ -n "$helper" ] || return 0
  python3 "$helper" --workspace "$PWD" --print-json 2>/dev/null || true
}

ensure_model_paths() {
  if [ -f "$REPO_ROOT/config/model-policy.jsonc" ]; then
    MODEL_CONFIG_PATH="$REPO_ROOT/config/model-policy.jsonc"
  elif [ -f "$MODEL_CONFIG_PATH_DEFAULT" ]; then
    MODEL_CONFIG_PATH="$MODEL_CONFIG_PATH_DEFAULT"
  elif [ -f "${MODEL_CONFIG_PATH_DEFAULT%.jsonc}.json" ]; then
    mv "${MODEL_CONFIG_PATH_DEFAULT%.jsonc}.json" "$MODEL_CONFIG_PATH_DEFAULT"
    MODEL_CONFIG_PATH="$MODEL_CONFIG_PATH_DEFAULT"
  else
    MODEL_CONFIG_PATH="$REPO_ROOT/config/model-policy.json"
  fi
  if [ -f "$MODEL_AVAILABILITY_PATH_DEFAULT" ]; then
    MODEL_AVAILABILITY_PATH="$MODEL_AVAILABILITY_PATH_DEFAULT"
  else
    MODEL_AVAILABILITY_PATH="$REPO_ROOT/config/model-availability.json"
  fi
  if [ -f "$REPO_ROOT/config/coding-protocol.jsonc" ]; then
    CODING_PROTOCOL_PATH="$REPO_ROOT/config/coding-protocol.jsonc"
  else
    CODING_PROTOCOL_PATH="$CODING_PROTOCOL_PATH_DEFAULT"
  fi
  [ -f "$MODEL_CONFIG_PATH" ] || die "ilongrun model policy not found"
}

preflight_or_die() {
  COPILOT_REAL_BIN="$(copilot_path || true)"
  [ -n "$COPILOT_REAL_BIN" ] || die "copilot CLI not found"
  ensure_model_paths
  detect_copilot_login >/dev/null 2>&1 || die "copilot CLI is not authenticated. Run: copilot login"
  auto_uninstall_legacy_plugin || die "legacy plugin '$LEGACY_PLUGIN_NAME' is still enabled; uninstall it before running ilongrun"
  cleanup_legacy_workspace_state >/dev/null 2>&1 || true
}

selected_model_for_payload() {
  local subcommand="$1"
  local payload="$2"
  local explicit_model="${3:-}"
  if [ "$subcommand" = "resume" ] && [ -z "$explicit_model" ]; then
    local resume_selected
    resume_selected="$(python3 - "$PWD" "$payload" "$SCRIPT_DIR" "$REPO_ROOT/scripts" "$HELPER_BIN_DIR" <<'PY'
import sys
from pathlib import Path

workspace = Path(sys.argv[1])
run_ref = sys.argv[2]
script_paths = [Path(sys.argv[3]), Path(sys.argv[4]), Path(sys.argv[5])]
for script_dir in script_paths:
    lib = script_dir / "_ilongrun_lib.py"
    if lib.exists():
        sys.path.insert(0, str(script_dir))
        break
try:
    from _ilongrun_lib import resolve_run_target, scheduler_path, read_json  # type: ignore
    target = resolve_run_target(workspace, run_ref)
    sched = read_json(scheduler_path(target), {})
    print(str(sched.get("selectedModel") or "").strip())
except Exception:
    print("")
PY
)"
    if [ -n "$resume_selected" ]; then
      printf '%s\n' "$resume_selected"
      return 0
    fi
  fi
  local helper
  helper="$(helper_path model_policy_info.py || true)"
  [ -n "$helper" ] || { printf 'claude-sonnet-4.6\n'; return 0; }
  local skill_name="ilongrun"
  case "$subcommand" in
    run) skill_name="ilongrun" ;;
    coding) skill_name="ilongrun-coding" ;;
    prompt) skill_name="ilongrun-prompt" ;;
    resume) skill_name="ilongrun-resume" ;;
    status) skill_name="ilongrun-status" ;;
    doctor) skill_name="ilongrun-doctor" ;;
  esac
  local role_name="mission-governor"
  [ "$subcommand" = "coding" ] && role_name="executor"
  [ "$subcommand" = "status" ] && role_name="mission-governor"
  local cmd=(python3 "$helper" --config "$MODEL_CONFIG_PATH" --availability-cache "$MODEL_AVAILABILITY_PATH" --subcommand "$subcommand" --skill "$skill_name" --role "$role_name" --payload "$payload" --json)
  [ -n "$explicit_model" ] && cmd+=(--explicit-model "$explicit_model")
  "${cmd[@]}" | python3 -c 'import json,sys; print(json.load(sys.stdin)["selected"])'
}

shell_join() {
  python3 - "$@" <<'PY'
import shlex, sys
print(shlex.join(sys.argv[1:]))
PY
}

write_meta() {
  local path="$1" subcommand="$2" payload="$3" log_file="$4" mode="$5" command_line="$6" selected_model="$7"
  python3 - "$path" "$subcommand" "$payload" "$log_file" "$mode" "$command_line" "$selected_model" <<'PY'
import json, os, sys
from datetime import datetime, timezone
from pathlib import Path
path = Path(sys.argv[1])
path.parent.mkdir(parents=True, exist_ok=True)
obj = {
    'startedAt': datetime.now(timezone.utc).isoformat(),
    'cwd': os.getcwd(),
    'subcommand': sys.argv[2],
    'payload': sys.argv[3],
    'logFile': sys.argv[4],
    'skillResolution': sys.argv[5],
    'command': sys.argv[6],
    'selectedModel': sys.argv[7],
}
path.write_text(json.dumps(obj, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
PY
}

launch_detached_via_screen() {
  local subcommand="$1" payload="$2" log_file="$3" meta_file="$4" selected_model="$5" run_ref="$6"
  shift 6
  local screen_bin session_name joined workspace_q log_q board_helper
  screen_bin="$(screen_path || true)"
  [ -n "$screen_bin" ] || die "Detached mode requires screen"
  session_name="ilongrun-${subcommand}-$(date +%Y%m%d-%H%M%S)"
  joined="$(shell_join "$@")"
  workspace_q="$(python3 - <<'PY' "$PWD"
import shlex,sys
print(shlex.quote(sys.argv[1]))
PY
)"
  log_q="$(python3 - <<'PY' "$log_file"
import shlex,sys
print(shlex.quote(sys.argv[1]))
PY
)"
  "$screen_bin" -dmS "$session_name" bash -lc "cd $workspace_q && $joined >> $log_q 2>&1"
  write_meta "$meta_file" "$subcommand" "$payload" "$log_file" "$SKILL_MODE" "$joined" "$selected_model"
  board_helper="$(helper_path render_ilongrun_launch_board.py || true)"
  if [ -n "$board_helper" ]; then
    python3 "$board_helper" \
      --workspace "$PWD" \
      --run-id "$run_ref" \
      --subcommand "$subcommand" \
      --log-file "$log_file" \
      --meta-file "$meta_file" \
      --selected-model "$selected_model" \
      --model-config "$MODEL_CONFIG_PATH" \
      || true
  else
    printf '[OK] detached session started: %s\n' "$session_name"
    printf '  log: %s\n' "$log_file"
    printf '  meta: %s\n' "$meta_file"
    printf '  status: ilongrun-status %s\n' "$run_ref"
  fi
  send_launch_notification "$subcommand" "$run_ref"
}

send_launch_notification() {
  local subcommand="$1" run_ref="$2"
  local helper event title subtitle message
  helper="$(helper_path notify_macos.py || true)"
  [ -n "$helper" ] || return 0
  case "$subcommand" in
    resume)
      event="resumed"
      title="iLongRun 已经接着跑起来了"
      subtitle="任务正在后台继续进行"
      message="你现在可以先去忙别的，iLongRun 会继续往前推进。"
      ;;
    *)
      event="launched"
      title="iLongRun 已经开始了"
      subtitle="任务正在后台继续进行"
      message="你现在可以关掉终端，稍后回来再看进度。"
      ;;
  esac
  python3 "$helper" \
    --workspace "$PWD" \
    --run-id "$run_ref" \
    --event "$event" \
    --title "$title" \
    --subtitle "$subtitle" \
    --message "$message" \
    >/dev/null 2>&1 || true
}

doctor() {
  local refresh_cache="${1:-0}"
  local notify_test="${2:-0}"
  local issues=0
  local copilot_bin="$(copilot_path || true)"
  local screen_bin="$(screen_path || true)"
  local mac_notifier="$(terminal_notifier_path || true)"
  local login="$(detect_copilot_login || true)"
  local helper_selftest="$(helper_path selftest_ilongrun.py || true)"
  local helper_probe="$(helper_path probe_models.py || true)"
  local helper_fleet_probe="$(helper_path probe_fleet_capability.py || true)"
  local helper_notify="$(helper_path notify_macos.py || true)"
  local helper_cleanup="$(helper_path cleanup_legacy_workspace.py || true)"
  local helper_model="$(helper_path manage_ilongrun_model.py || true)"
  local helper_render_board="$(helper_path render_ilongrun_doctor_board.py || true)"
  local helper_skill_lint="$(helper_path lint_ilongrun_skills.py || true)"
  local helper_verify="$(helper_path verify_ilongrun_run.py || true)"
  local expected_launchers=(ilongrun ilongrun-coding ilongrun-model ilongrun-prompt ilongrun-resume ilongrun-status ilongrun-doctor copilot-ilongrun)
  local coding_playbooks=(phase-define.md phase-plan.md phase-build.md phase-verify.md phase-review.md phase-audit.md phase-finalize.md swarm-policy.md js-ts-profile.md workspace-isolation.md task-microcycle.md claim-verification.md recovery-debug.md skill-engineering.md)
  local tmp_dir checks_file model_probe_json fleet_probe_json selftest_err selftest_out selftest_state_log fleet_cache_path workspace_run_json
  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/ilongrun-doctor.XXXXXX")"
  checks_file="$tmp_dir/checks.tsv"
  model_probe_json="$tmp_dir/model-probe.json"
  fleet_probe_json="$tmp_dir/fleet-probe.json"
  workspace_run_json="$tmp_dir/workspace-run.json"
  selftest_err="$tmp_dir/selftest.err"
  selftest_out="$tmp_dir/selftest.out"
  fleet_cache_path="$ILONGRUN_HOME/config/capabilities.json"
  mkdir -p "$ILONGRUN_HOME/state" "$ILONGRUN_HOME/config"
  selftest_state_log="$ILONGRUN_HOME/state/doctor-last-selftest.err"

  doctor_row() {
    local key="$1" status="$2" value="$3"
    value="${value//$'\t'/ }"
    value="${value//$'\n'/ }"
    printf '%s\t%s\t%s\n' "$key" "$status" "$value" >> "$checks_file"
  }

  write_model_probe_stub() {
    python3 - "$model_probe_json" "$1" "$2" "$3" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
payload = {
    "ok": False,
    "identity": sys.argv[2],
    "cache": sys.argv[3],
    "reason": sys.argv[4],
    "models": {},
}
path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY
  }

  write_fleet_probe_stub() {
    python3 - "$fleet_probe_json" "$1" "$2" "$3" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
payload = {
    "ok": False,
    "identity": sys.argv[2],
    "cache": sys.argv[3],
    "reason": sys.argv[4],
    "status": "unknown",
}
path.write_text(json.dumps(payload, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY
  }

  ensure_model_paths || true
  for launcher in "${expected_launchers[@]}"; do
    local launcher_path
    launcher_path="$(find_bin_from_common_locations "$launcher" || true)"
    if [ -n "$launcher_path" ]; then
      doctor_row "launcher.$launcher" ok "$launcher_path"
      continue
    fi
    if [ "$launcher" = "ilongrun-coding" ] && has_personal_skill ilongrun-coding; then
      doctor_row "launcher.$launcher" fail "skill 已安装，但 shell 命令未安装；请重新执行 install.sh"
    else
      doctor_row "launcher.$launcher" fail "未检测到；建议重新执行安装脚本"
    fi
    issues=$((issues+1))
  done
  if [ -n "$copilot_bin" ]; then doctor_row copilot ok "$copilot_bin"; else doctor_row copilot fail "未检测到 copilot CLI"; issues=$((issues+1)); fi
  if [ -n "$login" ]; then doctor_row login ok "$login"; else doctor_row login fail "未登录 GitHub Copilot"; issues=$((issues+1)); fi
  if [ -f "$MODEL_CONFIG_PATH" ]; then doctor_row model_policy ok "$MODEL_CONFIG_PATH"; else doctor_row model_policy fail "模型配置文件缺失"; issues=$((issues+1)); fi
  if [ -f "$CODING_PROTOCOL_PATH" ]; then
    local protocol_check
    protocol_check="$(python3 - "$CODING_PROTOCOL_PATH" "$HELPER_BIN_DIR" <<'PY'
import sys
from pathlib import Path
sys.path.insert(0, sys.argv[2])
from _ilongrun_shared import read_jsonc
payload = read_jsonc(Path(sys.argv[1]), {})
required = [
    "methodologyOverlay",
    "workspaceIsolationPolicy",
    "taskMicrocycle",
    "claimVerificationPolicy",
    "debugPolicy",
    "skillEngineeringPolicy",
]
missing = [key for key in required if key not in payload]
print("ok" if not missing else "missing:" + ",".join(missing))
PY
)"
    if [ "$protocol_check" = "ok" ]; then
      doctor_row coding_protocol ok "$CODING_PROTOCOL_PATH"
    else
      doctor_row coding_protocol fail "coding protocol 缺字段：${protocol_check#missing:}"
      issues=$((issues+1))
    fi
  else
    doctor_row coding_protocol fail "coding protocol 缺失"
    issues=$((issues+1))
  fi
  if [ -f "$ILONGRUN_HOME/vendor/agent-skills/LICENSE" ]; then
    doctor_row vendor_snapshot ok "$ILONGRUN_HOME/vendor/agent-skills"
  else
    doctor_row vendor_snapshot fail "vendor/agent-skills 快照缺失"
    issues=$((issues+1))
  fi
  local missing_playbooks=()
  for playbook in "${coding_playbooks[@]}"; do
    [ -f "$HOME/.copilot/skills/ilongrun-coding/$playbook" ] || missing_playbooks+=("$playbook")
  done
  if [ "${#missing_playbooks[@]}" -eq 0 ]; then
    doctor_row coding_playbooks ok "$HOME/.copilot/skills/ilongrun-coding"
  else
    doctor_row coding_playbooks fail "缺失：${missing_playbooks[*]}"
    issues=$((issues+1))
  fi
  local missing_agents=()
  for agent in ilongrun-test-engineer.agent.md ilongrun-security-auditor.agent.md ilongrun-final-audit-reviewer.agent.md; do
    [ -f "$HOME/.copilot/agents/$agent" ] || missing_agents+=("$agent")
  done
  if [ "${#missing_agents[@]}" -eq 0 ]; then
    doctor_row coding_agents ok "$HOME/.copilot/agents"
  else
    doctor_row coding_agents fail "缺失：${missing_agents[*]}"
    issues=$((issues+1))
  fi
  if [ -n "$helper_skill_lint" ] && [ -f "$helper_skill_lint" ]; then
    doctor_row skill_lint ok "$helper_skill_lint"
  else
    doctor_row skill_lint fail "lint_ilongrun_skills.py 缺失"
    issues=$((issues+1))
  fi
  if [ -n "$helper_model" ] && [ -f "$helper_model" ]; then
    doctor_row model_helper ok "$helper_model"
  else
    doctor_row model_helper fail "manage_ilongrun_model.py 缺失"
    issues=$((issues+1))
  fi
  if [ -f "$HOME/.copilot/skills/ilongrun-model/SKILL.md" ]; then
    doctor_row legacy_skill.ilongrun-model warn "$HOME/.copilot/skills/ilongrun-model（legacy 会话入口残留，可清理）"
  else
    doctor_row legacy_skill.ilongrun-model skip "未发现旧 /ilongrun-model skill 残留"
  fi
  if legacy_plugin_enabled; then
    if auto_uninstall_legacy_plugin >/dev/null 2>&1; then
      doctor_row legacy_plugin ok "已自动卸载：${LEGACY_PLUGIN_NAME}"
    else
      doctor_row legacy_plugin fail "仍处于启用状态：${LEGACY_PLUGIN_NAME}"
      issues=$((issues+1))
    fi
  else
    doctor_row legacy_plugin ok "未启用（${LEGACY_PLUGIN_NAME}）"
  fi
  if [ -n "$helper_cleanup" ]; then
    cleanup_result="$(python3 "$helper_cleanup" --workspace "$PWD" --print-json 2>/dev/null || true)"
    cleanup_action="$(printf '%s' "$cleanup_result" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("action","noop"))' 2>/dev/null || printf 'noop')"
    cleanup_archive="$(printf '%s' "$cleanup_result" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("archivePath") or "")' 2>/dev/null || true)"
    if [ "$cleanup_action" = "noop" ]; then
      doctor_row workspace_legacy ok "未发现旧工作区残留"
    else
      doctor_row workspace_legacy ok "已清理：$cleanup_action"
      [ -n "$cleanup_archive" ] && doctor_row workspace_archive info "$cleanup_archive"
    fi
  fi
  if [ -d "$PWD/.copilot-ilongrun" ] && [ -n "$helper_verify" ]; then
    local workspace_active_run workspace_latest_run workspace_target_run
    workspace_active_run="$(cat "$PWD/.copilot-ilongrun/state/active-run-id" 2>/dev/null || true)"
    workspace_latest_run="$(cat "$PWD/.copilot-ilongrun/state/latest-run-id" 2>/dev/null || true)"
    workspace_target_run="${workspace_active_run:-$workspace_latest_run}"
    if [ -n "$workspace_target_run" ]; then
      doctor_row workspace_run info "active=${workspace_active_run:-none} / latest=${workspace_latest_run:-none} / target=${workspace_target_run}"
      python3 "$helper_verify" --workspace "$PWD" --run-id "$workspace_target_run" --json >"$workspace_run_json" 2>"$tmp_dir/workspace-run.err" || true
      if ! python3 - "$workspace_run_json" "$checks_file" <<'PY'
import json, sys
from pathlib import Path

payload_path = Path(sys.argv[1])
checks_path = Path(sys.argv[2])
try:
    payload = json.loads(payload_path.read_text(encoding="utf-8"))
except Exception:
    payload = {}

rows = []
hard = [str(item) for item in payload.get("hardFailures") or []]
drift = [str(item) for item in payload.get("driftFindings") or []]
soft = [str(item) for item in payload.get("softWarnings") or []]
ok = bool(payload.get("ok"))
scheduler = payload.get("scheduler") or {}
run_id = str((scheduler.get("runId") or "")).strip() or "unknown"

def add(key: str, status: str, value: str) -> None:
    rows.append((key, status, value.replace("\t", " ").replace("\n", " ")))

if not payload:
    add("workspace_run_verification", "warn", "当前工作区 run 健康检查结果不可读")
    overall_fail = False
else:
    if ok:
        add("workspace_run_verification", "ok", f"run `{run_id}` 账本与门禁通过")
    else:
        add("workspace_run_verification", "fail", f"run `{run_id}` 需处理：hard={len(hard)} / drift={len(drift)} / soft={len(soft)}")
    if payload.get("recommendedAction"):
        add("workspace_run_action", "info", str(payload.get("recommendedAction")))

    findings = hard + drift
    state_conflict = next((item for item in findings if "scheduler.status" in item or "invalid canonical scheduler.state" in item), "")
    add("workspace_run_state_conflict", "fail" if state_conflict else "skip", state_conflict or "未发现 top-level state/status 冲突")

    active_pointer = next((item for item in findings if "active-run-id" in item), "")
    add("workspace_run_active_pointer", "fail" if active_pointer else "skip", active_pointer or "未发现已完成 run 的 active 指针残留")

    finalize_issue = next((
        item for item in findings
        if "COMPLETION.md" in item
        or "BLOCKED.md" in item
        or "FAILED.md" in item
        or "reviews/final-review.md is missing" in item
        or "reviews/adjudication.md is missing" in item
        or "running run must not contain terminal summary documents" in item
    ), "")
    add("workspace_run_finalize", "fail" if finalize_issue else "skip", finalize_issue or "未发现终态摘要或 finalize 门禁异常")

    placeholder_issue = next((item for item in findings if "workstream marked done without structured evidence" in item), "")
    add("workspace_run_review_placeholder", "fail" if placeholder_issue else "skip", placeholder_issue or "未发现 review/result/evidence 伪完成")

    pollution_issue = next((item for item in findings if "workspace tracks generated artifacts" in item), "")
    add("workspace_run_pollution", "fail" if pollution_issue else "skip", pollution_issue or "未发现 git 跟踪的生成态目录污染")
    overall_fail = not ok

with checks_path.open("a", encoding="utf-8") as handle:
    for key, status, value in rows:
        handle.write(f"{key}\t{status}\t{value}\n")

raise SystemExit(1 if overall_fail else 0)
PY
      then
        issues=$((issues+1))
      fi
    else
      doctor_row workspace_run skip "当前工作区没有 active/latest run"
    fi
  elif [ -d "$PWD/.copilot-ilongrun" ]; then
    doctor_row workspace_run warn "检测到 .copilot-ilongrun，但 verify helper 缺失"
  else
    doctor_row workspace_run skip "当前工作区没有 .copilot-ilongrun 运行状态"
  fi
  if [ -n "$screen_bin" ]; then doctor_row screen ok "$screen_bin"; else doctor_row screen warn "未检测到；将无法使用 --detach"; fi
  if [ "$(uname -s)" = "Darwin" ]; then
    if [ -n "$mac_notifier" ]; then
      doctor_row terminal_notifier ok "$mac_notifier"
    elif [ -n "$helper_notify" ]; then
      doctor_row terminal_notifier warn "未检测到 terminal-notifier；会自动回退到 osascript"
    else
      doctor_row terminal_notifier warn "提醒 helper 缺失"
    fi
  else
    doctor_row terminal_notifier info "当前不是 macOS，无需 terminal-notifier"
  fi
  if [ -n "$helper_probe" ] && [ -n "$copilot_bin" ] && [ -n "$login" ]; then
    local cmd=(python3 "$helper_probe" --copilot-bin "$copilot_bin" --config "$MODEL_CONFIG_PATH" --cache "$MODEL_AVAILABILITY_PATH" --scope defaults --json)
    [ "$refresh_cache" = "1" ] && cmd+=(--refresh)
    if ! "${cmd[@]}" >"$model_probe_json" 2>"$tmp_dir/model-probe.err"; then
      write_model_probe_stub "${login:-}" "$MODEL_AVAILABILITY_PATH" "probe-command-failed"
    fi
  elif [ -z "$login" ]; then
    write_model_probe_stub "" "$MODEL_AVAILABILITY_PATH" "skipped-no-login"
  elif [ -z "$copilot_bin" ]; then
    write_model_probe_stub "${login:-}" "$MODEL_AVAILABILITY_PATH" "skipped-no-copilot"
  else
    write_model_probe_stub "${login:-}" "$MODEL_AVAILABILITY_PATH" "probe-helper-missing"
  fi
  if [ -n "$helper_selftest" ]; then
    if python3 "$helper_selftest" >"$selftest_out" 2>"$selftest_err"; then
      doctor_row selftest ok "已通过"
      rm -f "$selftest_state_log"
    else
      cp "$selftest_err" "$selftest_state_log"
      doctor_row selftest fail "未通过"
      doctor_row selftest_log info "$selftest_state_log"
      issues=$((issues+1))
    fi
  else
    doctor_row selftest warn "selftest helper 缺失，未执行"
  fi
  if [ -n "$helper_fleet_probe" ] && [ -n "$copilot_bin" ] && [ -n "$login" ]; then
    local probe_cmd=(python3 "$helper_fleet_probe" --copilot-bin "$copilot_bin" --model-config "$MODEL_CONFIG_PATH" --availability-cache "$MODEL_AVAILABILITY_PATH" --cache "$fleet_cache_path" --json)
    [ "$refresh_cache" = "1" ] && probe_cmd+=(--refresh)
    if ! "${probe_cmd[@]}" >"$fleet_probe_json" 2>"$tmp_dir/fleet-probe.err"; then
      write_fleet_probe_stub "${login:-}" "$fleet_cache_path" "probe-command-failed"
    fi
  elif [ -z "$login" ]; then
    write_fleet_probe_stub "" "$fleet_cache_path" "skipped-no-login"
  elif [ -z "$copilot_bin" ]; then
    write_fleet_probe_stub "${login:-}" "$fleet_cache_path" "skipped-no-copilot"
  else
    write_fleet_probe_stub "${login:-}" "$fleet_cache_path" "probe-helper-missing"
  fi
  if [ "$notify_test" = "1" ]; then
    if [ "$(uname -s)" != "Darwin" ]; then
      doctor_row notify_test warn "当前不是 macOS，已跳过提醒测试"
    elif [ -z "$helper_notify" ]; then
      doctor_row notify_test fail "提醒 helper 缺失，无法测试系统通知"
      issues=$((issues+1))
    else
      if python3 "$helper_notify" \
        --workspace "$PWD" \
        --event attention \
        --title "iLongRun 通知测试" \
        --subtitle "这是一次提醒链路自检" \
        --message "如果你没有看到这条提醒，请检查系统通知权限、专注模式和通知摘要。" \
        --open "$PWD" \
        --sound \
        --dedupe-seconds 0 \
        --group "ilongrun.doctor-test.$(date +%s)" >/dev/null 2>&1; then
        doctor_row notify_test ok "已发送，请留意系统通知横幅"
      else
        doctor_row notify_test fail "发送失败，请检查系统通知权限"
        issues=$((issues+1))
      fi
    fi
  fi
  if [ -n "$helper_render_board" ]; then
    python3 "$helper_render_board" \
      --checks-file "$checks_file" \
      --model-probe-json "$model_probe_json" \
      --fleet-probe-json "$fleet_probe_json" \
      --selftest-log "$selftest_state_log" \
      --refresh-cache "$refresh_cache" \
      --notify-test "$notify_test"
  else
    cat "$checks_file"
  fi
  rm -rf "$tmp_dir"
  [ "$issues" -eq 0 ]
}

subcmd="${1:-help}"
shift || true
case "$subcmd" in
  help|-h|--help) usage; exit 0 ;;
  doctor)
    refresh_model_cache=0
    notify_test=0
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --refresh-model-cache) refresh_model_cache=1; shift ;;
        --notify-test) notify_test=1; shift ;;
        *) die "unknown option: $1" ;;
      esac
    done
    doctor "$refresh_model_cache" "$notify_test"
    exit $?
    ;;
  selftest)
    helper="$(helper_path selftest_ilongrun.py || true)"
    [ -n "$helper" ] || die "selftest helper missing"
    exec python3 "$helper"
    ;;
esac

if [ "$subcmd" = "status" ]; then
  ensure_model_paths || true
  cleanup_legacy_workspace_state >/dev/null 2>&1 || true
  helper="$(helper_path render_ilongrun_status_board.py || true)"
  if [ -n "$helper" ]; then
    exec python3 "$helper" --workspace "$PWD" --run-id "${1:-latest}" --model-config "$MODEL_CONFIG_PATH"
  fi
fi

if [ "$subcmd" = "model" ]; then
  helper="$(helper_path manage_ilongrun_model.py || true)"
  [ -n "$helper" ] || die "model helper missing"
  exec python3 "$helper" --workspace "$PWD" "$@"
fi

preflight_or_die

model=""
max_continues="$DEFAULT_MAX_CONTINUES"
detach=0
dry_run=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --detach) detach=1; shift ;;
    --dry-run) dry_run=1; shift ;;
    --max-continues) [ "$#" -ge 2 ] || die "--max-continues requires a value"; max_continues="$2"; shift 2 ;;
    --model) [ "$#" -ge 2 ] || die "--model requires a value"; model="$2"; shift 2 ;;
    --) shift; break ;;
    -*) die "unknown option: $1" ;;
    *) break ;;
  esac
done

payload_text=""
force_profile=""
case "$subcmd" in
  run)
    [ "$#" -ge 1 ] || die "run requires a task description"
    resolve_skill_ref ilongrun || die "ilongrun skill source not found"
    resolve_skill_ref ilongrun-resume >/dev/null || true
    RESOLVED_RESUME_SKILL_REF="${RESOLVED_SKILL_REF:-/ilongrun-resume}"
    resolve_skill_ref ilongrun || true
    payload_text="$*"
    ;;
  coding)
    [ "$#" -ge 1 ] || die "coding requires a task description"
    force_profile="coding"
    resolve_skill_ref ilongrun || die "ilongrun skill source not found"
    resolve_skill_ref ilongrun-resume >/dev/null || true
    RESOLVED_RESUME_SKILL_REF="${RESOLVED_SKILL_REF:-/ilongrun-resume}"
    resolve_skill_ref ilongrun || true
    payload_text="$*"
    ;;
  prompt)
    [ "$#" -ge 1 ] || die "prompt requires a task description"
    resolve_skill_ref ilongrun-prompt || die "ilongrun-prompt skill source not found"
    payload_text="$*"
    ;;
  resume)
    payload_text="${1:-latest}"
    resolve_skill_ref ilongrun-resume || die "ilongrun-resume skill source not found"
    RESOLVED_RESUME_SKILL_REF="$RESOLVED_SKILL_REF"
    ;;
  status)
    payload_text="${1:-latest}"
    resolve_skill_ref ilongrun-status || die "ilongrun-status skill source not found"
    ;;
  *) die "unknown subcommand: $subcmd" ;;
esac
skill_ref="$RESOLVED_SKILL_REF"
resume_skill_ref="$RESOLVED_RESUME_SKILL_REF"
selected_model="$(selected_model_for_payload "$subcmd" "$payload_text" "$model" || true)"
[ -n "$selected_model" ] || selected_model="${model:-claude-sonnet-4.6}"

prepared_run_id=""
prepared_run_dir=""
prepared_scheduler_path=""
prepared_workstreams_dir=""
supervisor_mode="$subcmd"
[ "$subcmd" = "coding" ] && supervisor_mode="run"
if [ "$subcmd" = "run" ] || [ "$subcmd" = "coding" ]; then
  PREPARE_RUN="$(helper_path prepare_ilongrun_run.py || true)"
  [ -n "$PREPARE_RUN" ] || die "prepare_ilongrun_run helper missing"
  if [ "$dry_run" -eq 0 ]; then
    model_control_mode="launcher-enforced"
    [ -n "$model" ] && model_control_mode="explicit-model-locked"
    prepare_cmd=(python3 "$PREPARE_RUN" --workspace "$PWD" --task "$payload_text" --launcher-mode launcher-preallocated --session-model "$selected_model" --model-control-mode "$model_control_mode" --print-json)
    [ -n "$model" ] && prepare_cmd+=(--explicit-model "$model")
    [ -n "$force_profile" ] && prepare_cmd+=(--force-profile "$force_profile")
    prepared_json="$("${prepare_cmd[@]}")" || die "failed to prepare fresh ILongRun run"
    prepared_run_id="$(printf '%s' "$prepared_json" | python3 -c 'import json,sys; print(json.load(sys.stdin)["runId"])')"
    prepared_run_dir="$(printf '%s' "$prepared_json" | python3 -c 'import json,sys; print(json.load(sys.stdin)["runDir"])')"
    prepared_scheduler_path="$(printf '%s' "$prepared_json" | python3 -c 'import json,sys; print(json.load(sys.stdin)["schedulerPath"])')"
    prepared_workstreams_dir="$(printf '%s' "$prepared_json" | python3 -c 'import json,sys; print(json.load(sys.stdin)["workstreamsDir"])')"
  fi
fi

SUPERVISOR="$(helper_path launch_ilongrun_supervisor.py || true)"
[ -n "$SUPERVISOR" ] || die "launch_ilongrun_supervisor helper missing"

supervisor_cmd=(python3 "$SUPERVISOR" --workspace "$PWD" --copilot-bin "$COPILOT_REAL_BIN" --mode "$supervisor_mode" --skill-ref "$skill_ref" --payload "$payload_text" --max-continues "$max_continues" --model-config "$MODEL_CONFIG_PATH" --availability-cache "$MODEL_AVAILABILITY_PATH")
[ -n "$resume_skill_ref" ] && supervisor_cmd+=(--resume-skill-ref "$resume_skill_ref")
for arg in "${PLUGIN_ARGS[@]:-}"; do [ -n "$arg" ] && supervisor_cmd+=(--plugin-arg "$arg"); done
[ -n "$prepared_run_id" ] && supervisor_cmd+=(--target-run-id "$prepared_run_id")
[ -n "$prepared_run_dir" ] && supervisor_cmd+=(--target-run-dir "$prepared_run_dir")
[ -n "$prepared_scheduler_path" ] && supervisor_cmd+=(--target-scheduler-path "$prepared_scheduler_path")
[ -n "$prepared_workstreams_dir" ] && supervisor_cmd+=(--target-workstreams-dir "$prepared_workstreams_dir")
[ -z "$prepared_run_id" ] && [ "$subcmd" = "resume" ] && supervisor_cmd+=(--target-run-id "$payload_text")
[ -n "$model" ] && supervisor_cmd+=(--explicit-model "$model")
[ -n "$force_profile" ] && supervisor_cmd+=(--force-profile "$force_profile")

if [ "$dry_run" -eq 1 ]; then
  actual_cmd=("$COPILOT_REAL_BIN")
  for arg in "${PLUGIN_ARGS[@]:-}"; do [ -n "$arg" ] && actual_cmd+=(--plugin-dir "$arg"); done
  if [ "$subcmd" = "run" ] || [ "$subcmd" = "coding" ] || [ "$subcmd" = "resume" ]; then
    actual_cmd+=(--autopilot --yolo --no-ask-user --max-autopilot-continues "$max_continues")
  else
    actual_cmd+=(--yolo --no-ask-user)
  fi
  actual_cmd+=(--model "$selected_model" -p "$skill_ref $payload_text")
  shell_join "${actual_cmd[@]}"
  exit 0
fi

if [ "$detach" -eq 1 ] && { [ "$subcmd" = "run" ] || [ "$subcmd" = "coding" ] || [ "$subcmd" = "resume" ]; }; then
  launcher_dir="$PWD/$LAUNCHER_DIR_NAME"
  mkdir -p "$launcher_dir"
  ts="$(date +%Y%m%d-%H%M%S)"
  log_file="$launcher_dir/${subcmd}-${ts}.log"
  meta_file="$launcher_dir/${subcmd}-${ts}.json"
  launch_run_ref="${prepared_run_id:-$payload_text}"
  launch_detached_via_screen "$subcmd" "$payload_text" "$log_file" "$meta_file" "$selected_model" "$launch_run_ref" "${supervisor_cmd[@]}"
  exit 0
fi

exec "${supervisor_cmd[@]}"
